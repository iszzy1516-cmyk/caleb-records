{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://culrecords.duckdns.org" },
        { "url": "https://*.duckdns.org" },
        { "url": "http://98.85.146.214" },
        { "url": "https://98.85.146.214" },
        { "url": "https://*.s3.amazonaws.com" },
        { "url": "https://*.s3.*.amazonaws.com" }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://*.s3.amazonaws.com" }, { "url": "https://*.s3.*.amazonaws.com" }]
    }
  ]
}
