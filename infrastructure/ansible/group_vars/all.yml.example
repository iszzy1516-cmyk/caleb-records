---
# Auto-generated by Terraform
# Copy this file to all.yml and fill in the placeholders:
#   cp group_vars/all.yml.example group_vars/all.yml

app_name: culrecords
app_dir: "/home/ubuntu/{{ app_name }}"

# Domain and SSL (optional)
domain_name: ""  # e.g. "records.example.com"
use_ssl: false

# Database configuration
db_user: calebrecords
db_password: "CHANGE_ME_OR_USE_TERRAFORM_VALUE"
db_name: calebrecords

# Backend secret
secret_key: "CHANGE_ME_OR_USE_TERRAFORM_VALUE"

# CORS origins - update with your production domains
cors_origins: "http://localhost:5173,http://localhost:5174,https://tauri.localhost,http://98.85.146.214,http://98.85.146.214/staff"

# SMTP configuration (optional)
smtp_host: ""
smtp_port: 587
smtp_user: ""
smtp_password: ""
smtp_from: "noreply@calebuniversity.edu.ng"

# S3 backup bucket (auto-generated by Terraform)
s3_backup_bucket: "culrecords-backups-789a09a5"

# S3 upload bucket (auto-generated by Terraform)
s3_upload_bucket: "culrecords-uploads-789a09a5"
aws_region: "us-east-1"
# aws_access_key_id: ""  # optional; leave empty to use EC2 instance profile
# aws_secret_access_key: ""

# Document verification (Vision AI)
vision_provider: "openai"
openai_api_key: ""
gemini_api_key: ""
ollama_base_url: "http://localhost:11434"
vision_verify_uploads: "true"
vision_min_confidence: "0.7"

# RDS endpoint (only used if create_rds = true in Terraform)
rds_endpoint: ""

# Git repository to clone
git_repo: "https://github.com/YOUR_USERNAME/caleb-records.git"
git_branch: "main"
