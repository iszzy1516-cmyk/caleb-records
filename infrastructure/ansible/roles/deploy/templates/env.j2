# CU-Records Production Environment
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_NAME={{ db_name }}
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@db:5432/{{ db_name }}
SECRET_KEY={{ secret_key }}
CORS_ORIGINS={{ cors_origins }}
FRONTEND_URL=http://{{ ansible_host }}
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# SMTP Configuration
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port }}
SMTP_USER={{ smtp_user }}
SMTP_PASS={{ smtp_password }}
SMTP_FROM={{ smtp_from }}

# S3 Backup (optional)
S3_BACKUP_BUCKET={{ s3_backup_bucket }}

# S3 Document Uploads
S3_UPLOAD_BUCKET={{ s3_upload_bucket }}
AWS_REGION={{ aws_region | default('us-east-1') }}
AWS_ACCESS_KEY_ID={{ aws_access_key_id | default('') }}
AWS_SECRET_ACCESS_KEY={{ aws_secret_access_key | default('') }}
S3_PUBLIC_URL=https://{{ s3_upload_bucket }}.s3.{{ aws_region | default('us-east-1') }}.amazonaws.com

# Document Verification (Vision AI)
VISION_PROVIDER={{ vision_provider | default('openai') }}
OPENAI_API_KEY={{ openai_api_key | default('') }}
GEMINI_API_KEY={{ gemini_api_key | default('') }}
OLLAMA_BASE_URL={{ ollama_base_url | default('http://localhost:11434') }}
DASHSCOPE_API_KEY={{ dashscope_api_key | default('') }}
DASHSCOPE_BASE_URL={{ dashscope_base_url | default('https://dashscope-intl.aliyuncs.com/compatible-mode/v1') }}
DASHSCOPE_MODEL={{ dashscope_model | default('qwen-vl-max') }}
OVH_QWEN_BASE_URL={{ ovh_qwen_base_url | default('https://oai.endpoints.kepler.ai.cloud.ovh.net/v1') }}
OVH_QWEN_API_KEY={{ ovh_qwen_api_key | default('none') }}
VISION_VERIFY_UPLOADS={{ vision_verify_uploads | default('true') }}
VISION_REJECT_ON_FAILURE={{ vision_reject_on_failure | default('true') }}
VISION_MIN_CONFIDENCE={{ vision_min_confidence | default('0.7') }}
