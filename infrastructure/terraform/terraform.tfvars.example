aws_region      = "us-east-1"
environment     = "dev"
project_name    = "culrecords"
instance_type   = "t3.micro"
key_name        = "culrecords-deployer"
public_key_path = "~/.ssh/id_rsa.pub"

# Restrict SSH to your IP for security, e.g. "203.0.113.10/32"
allowed_ssh_cidr = "0.0.0.0/0"

# Optional: if you have a domain and want SSL
domain_name = ""

# Set to true to use RDS PostgreSQL (Free Tier eligible db.t3.micro)
# If false, PostgreSQL runs in Docker on the EC2 instance
create_rds = false

# Generate strong values:
# openssl rand -hex 32
db_password = "CHANGE_ME_TO_STRONG_PASSWORD"
secret_key  = "CHANGE_ME_TO_64_CHAR_HEX_SECRET"
