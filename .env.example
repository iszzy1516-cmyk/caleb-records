# ============================================
# Caleb Records — Production Environment
# ============================================

# Database (PostgreSQL via Docker)
DB_USER=calebrecords
DB_PASSWORD=STRONG_PASSWORD_HERE
DB_NAME=calebrecords
DATABASE_URL=postgresql://calebrecords:STRONG_PASSWORD_HERE@db:5432/calebrecords

# Security
SECRET_KEY=GENERATE_A_32_CHAR_RANDOM_STRING

# CORS — add your production frontend domains
CORS_ORIGINS=https://records.calebuniversity.edu.ng,https://student.calebuniversity.edu.ng,http://localhost:5173,http://localhost:5174,https://tauri.localhost,http://localhost:8089

# File uploads
MAX_FILE_SIZE=10485760

# SMTP (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@calebuniversity.edu.ng
SMTP_PASS=your-app-password
SMTP_FROM=noreply@calebuniversity.edu.ng

# Optional: S3/Cloudinary for file storage in production
# S3_UPLOAD_BUCKET=culrecords-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://culrecords-uploads.s3.amazonaws.com

# Document Verification (Vision AI)
# VISION_PROVIDER=openai       # openai | groq | gemini | dashscope | qwen | ollama
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=...
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-vl-max
# OLLAMA_BASE_URL=http://localhost:11434
# OVH_QWEN_BASE_URL=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1
# OVH_QWEN_API_KEY=none
# VISION_VERIFY_UPLOADS=true
# VISION_REJECT_ON_FAILURE=true
# VISION_MIN_CONFIDENCE=0.7
